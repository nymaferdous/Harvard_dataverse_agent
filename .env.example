# ─── Groq (free LLM API — get key at https://console.groq.com) ───────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192

# ─── Anthropic (optional — used by the LangChain ReAct agent) ────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Harvard Dataverse ────────────────────────────────────────────────────────
# Get your API token: https://dataverse.harvard.edu → Account → API Token
# For testing, use https://demo.dataverse.org instead
DATAVERSE_API_TOKEN=your-dataverse-api-token-here
DATAVERSE_BASE_URL=https://dataverse.harvard.edu
DATAVERSE_ALIAS=your-dataverse-alias-here

# ─── Dataset Author Info ──────────────────────────────────────────────────────
DATAVERSE_AUTHOR_NAME=Your Name
DATAVERSE_AUTHOR_AFFILIATION=Your Institution
DATAVERSE_CONTACT_EMAIL=your-email@example.com

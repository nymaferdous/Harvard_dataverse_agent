flowchart TD
    A([👤 Researcher\nUploads CSV via Browser]) --> B

    subgraph UI["🌐 Browser UI  (HTML / JS)"]
        B[Drag & Drop File\n+ Author Details]
    end

    B --> C

    subgraph API["⚙️ FastAPI REST Service"]
        C[POST /api/v1/pipeline/publish]
    end

    C --> D

    subgraph RAG["🧠 RAG Metadata Generator  (Free · Local)"]
        D[Extract Features\nColumn names · Sample values · Filename] --> E
        E[sentence-transformers\nEncode as vector] --> F
        F[(Knowledge Base\n20 Domain Examples\nBiomass · Marine · Agriculture…)] --> G
        G[Cosine Similarity Search\nFind closest match] --> H
        H[Fill Metadata Template\nTitle · Description · Keywords\nSubject · Time Period · Source]
    end

    H --> I

    subgraph AGENT["🤖 LangChain ReAct Agent  (claude-sonnet-4-6)"]
        I[Reason: What should I do next?] --> J
        J{Pick Tool} --> K
        J --> L
        J --> M
        J --> N
        J --> O
        K[🔍 search_dataverse\nCheck for duplicates]
        L[📁 create_dataverse_dataset\nPOST metadata → get DOI]
        M[📤 upload_file_to_dataset\nUpload CSV to draft]
        N[✅ get_dataset_info\nVerify before publish]
        O[🚀 publish_dataverse_dataset\nWait for ingest lock → Publish]
        K --> P[Observation]
        L --> P
        M --> P
        N --> P
        O --> P
        P --> I
    end

    O --> Q

    subgraph DV["🏛️ Harvard Dataverse  (dataverse.harvard.edu)"]
        Q[Dataset Published\nPermanent DOI assigned\nPublicly accessible]
    end

    Q --> R([✅ Browser shows\nPublic URL + DOI])

    style UI fill:#e8f4fd,stroke:#2196F3,color:#000
    style RAG fill:#e8f5e9,stroke:#4CAF50,color:#000
    style API fill:#fff3e0,stroke:#FF9800,color:#000
    style AGENT fill:#f3e5f5,stroke:#9C27B0,color:#000
    style DV fill:#fce4ec,stroke:#E91E63,color:#000
    style A fill:#2196F3,color:#fff,stroke:#1565C0
    style R fill:#4CAF50,color:#fff,stroke:#2E7D32
    style Q fill:#E91E63,color:#fff,stroke:#880E4F
